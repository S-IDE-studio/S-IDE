{
  "name": "side",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:web",
    "dev:web": "bun run --filter side-web dev",
    "dev:web:bun": "bun run --cwd apps/web dev",
    "dev:server": "bun run --filter side-server dev",
    "dev:desktop": "bun run --filter side-desktop dev",
    "dev:mobile": "bun run --filter side-mobile start",
    "build": "bun run build:web && bun run build:server && bun run build:desktop",
    "build:ui": "bun run --filter @side-ide/ui build",
    "build:web": "bun run --filter side-web build",
    "build:web:bun": "bun run --cwd apps/web build",
    "build:server": "bun run --filter side-server build",
    "build:desktop": "bun run build:web && bun run build:server && bun run --filter side-desktop build",
    "build:mobile": "bun run --filter side-mobile build",
    "build:mobile:ios": "bun run --filter side-mobile build:ios",
    "build:mobile:android": "bun run --filter side-mobile build:android",
    "bundle:server": "node scripts/bundle-server.js",
    "bundle:server:zip": "node scripts/create-server-bundle.js",
    "generate-icons": "node scripts/generate-icons.js",
    "serve": "bun run build:web && bun run build:server && bun run --filter side-server serve",
    "type-check": "bun run type-check:shared && bun run type-check:ui && bun run type-check:server && bun run type-check:web",
    "type-check:shared": "bun run --filter @side-ide/shared type-check",
    "type-check:ui": "bun run --filter @side-ide/ui type-check",
    "type-check:server": "bun run --filter side-server type-check",
    "type-check:web": "bun run --filter side-web type-check",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "bunx vitest run",
    "test:ui": "bunx vitest --ui",
    "test:watch": "bunx vitest",
    "test:coverage": "bunx vitest run --coverage",
    "test:ci": "bunx vitest run --coverage --reporter=verbose",
    "test:server": "bunx vitest --config apps/server/vitest.config.ts",
    "test:web": "cd apps/web && bunx vitest --config vitest.config.ts --run",
    "test:rust": "cd apps/desktop/src-tauri && cargo test",
    "ci": "bun run lint && bun run type-check && bun run test:ci && bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@testing-library/jest-dom": "^6.6.0",
    "archiver": "^7.0.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "eas-cli": "^10.0.0",
    "happy-dom": "^20.5.3",
    "vitest": "^2.1.0"
  }
}
